# LORD Automation — Environment Variables
# Copy this file to .env and fill in your keys.
# In production, set these as GitHub Repository Secrets (Settings → Secrets → Actions).

# ─── Required ─────────────────────────────────────────────────────────────────
# Claude API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Recommended ──────────────────────────────────────────────────────────────
# Unsplash API (free tier) — register at unsplash.com/developers
# Used to source editorial images for each article.
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# NewsAPI (free tier, 100 req/day) — register at newsapi.org
# Enhances news discovery beyond RSS feeds.
NEWS_API_KEY=your_newsapi_key_here

# Pexels API (free) — register at pexels.com/api
# Fallback image source if Unsplash is unavailable.
PEXELS_API_KEY=your_pexels_api_key_here

# Google Gemini API — aistudio.google.com/app/apikey (free tier available)
# Required for fact verification with Google Search grounding (PR-002).
# Set QUALITY_FACT_VERIFICATION=true in Actions secrets to activate.
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
